<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".CreateChapterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Chapter"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:id="@+id/tvStoryId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="#666666"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Chapter Title:"
            android:textSize="16sp"
            android:textColor="#4D4D4D"
            style="@style/Font_MontserratAlternates" />

        <EditText
            android:id="@+id/etChapterTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:hint="Enter chapter title"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Chapter Content:"
            android:textSize="16sp"
            android:textColor="#4D4D4D"
            style="@style/Font_MontserratAlternates" />

        <EditText
            android:id="@+id/etChapterContent"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:hint="Enter chapter content"
            android:padding="16dp"
            android:gravity="top|start"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            android:inputType="textMultiLine"
            android:scrollbars="vertical"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Option 1 Text:"
            android:textSize="16sp"
            android:textColor="#4D4D4D"
            style="@style/Font_MontserratAlternates" />

        <EditText
            android:id="@+id/etOption1"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:hint="Enter first option"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Option 2 Text:"
            android:textSize="16sp"
            android:textColor="#4D4D4D"
            style="@style/Font_MontserratAlternates" />

        <EditText
            android:id="@+id/etOption2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:hint="Enter second option"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            style="@style/Font_MontserratAlternates" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Voting Duration (days):"
            android:textSize="16sp"
            android:textColor="#4D4D4D"
            style="@style/Font_MontserratAlternates" />

        <EditText
            android:id="@+id/etVotingDuration"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:hint="Enter voting duration (e.g., 7)"
            android:padding="16dp"
            android:background="@drawable/edit_text_background"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            android:inputType="number"
            style="@style/Font_MontserratAlternates" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="CREATE CHAPTER"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            style="@style/Widget.App.Button.BlackSolid" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
